# Installation log
install.log

# ZSH runtime cache
config/zsh/.zcompdump*
config/zsh/.zsh_history

# Theme generation intermediates
themes/analysis/

# Active theme files (managed by theme-toggle.sh)
config/hypr/theme.conf
config/kitty/themes/active.conf
config/waybar/style.css
config/wofi/style.css
config/dunst/dunstrc
config/fastfetch/config.jsonc

# Wallpapers (too large for git)
wallpapers/*.png
wallpapers/*.jpg
wallpapers/*.jpeg
wallpapers/*.webp
!wallpapers/.gitkeep

# Auto-generated by apps at runtime
config/Thunar/accels.scm

# Secrets
config/zsh/.secrets

# OS / editor files
.DS_Store
*.swp
*~

# Plan file (session-only)
Plan.md
